# ─── server/.env ─────────────────────────────────────────────────────────────

# MongoDB Atlas connection string (get from Atlas > Database > Connect)
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/homewise

# Secret used to sign JWT tokens — generate with: openssl rand -hex 32
JWT_SECRET=your_jwt_secret_here

# Brevo API key (brevo.com — free tier: 300 emails/day)
BREVO_API_KEY=xkeysib-xxxxxxxxxxxxxxxxxxxx

# The "From" address for reminder emails. Must be a verified domain in Brevo.
BREVO_FROM_EMAIL=HomeWise <reminders@yourdomain.com>

# URL of the frontend — used for CORS. No trailing slash.
# Local dev: http://localhost:5173
# Production: https://yourdomain.vercel.app
CLIENT_URL=http://localhost:5173

# Port the Express server listens on (Railway sets this automatically)
PORT=3001

# ─── client/.env ─────────────────────────────────────────────────────────────

# Full URL of the backend API. No trailing slash.
# Local dev: http://localhost:3001
# Production: https://your-app.up.railway.app
VITE_API_URL=http://localhost:3001
